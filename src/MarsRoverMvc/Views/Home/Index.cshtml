@{
    ViewData["Title"] = "Home";
}

<div class="page-header">
    <h1 class="page-title">🚀 Mars Rover Simulator</h1>
    <p class="page-description">Navigate robotic rovers on the Martian plateau</p>
</div>

<div class="grid grid-2">
    <!-- New Simulation Card -->
    <div class="card">
        <h2 class="card-title">Start New Simulation</h2>
        <p style="color: #666; margin-bottom: 20px;">
            Configure a plateau, add rovers, and watch them navigate the Martian terrain.
        </p>
        <a href="/Simulation/Index" class="btn btn-primary">
            <span>▶</span>
            <span>Begin Simulation</span>
        </a>
    </div>

    <!-- History Card -->
    <div class="card">
        <h2 class="card-title">View History</h2>
        <p style="color: #666; margin-bottom: 20px;">
            Review all past simulations and their results on an interactive plateau.
        </p>
        <a href="/History/Index" class="btn btn-primary">
            <span>📚</span>
            <span>View History</span>
        </a>
    </div>
</div>

<!-- Instructions Card -->
<div class="card">
    <h2 class="card-title">How It Works</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        <div>
            <h3 style="color: #4CAF50; margin-bottom: 15px;">Rover Commands</h3>
            <ul style="margin-left: 20px; line-height: 1.8;">
                <li><strong>L</strong> - Rotate left 90°</li>
                <li><strong>R</strong> - Rotate right 90°</li>
                <li><strong>M</strong> - Move forward one grid point</li>
            </ul>
        </div>
        <div>
            <h3 style="color: #4CAF50; margin-bottom: 15px;">Example</h3>
            <p style="margin-bottom: 10px;"><strong>Plateau:</strong> 5 x 5</p>
            <p style="margin-bottom: 10px;"><strong>Rover Position:</strong> 1 2 N</p>
            <p style="margin-bottom: 10px;"><strong>Commands:</strong> LMLMLMLMM</p>
            <p><strong>Result:</strong> 1 3 N ✓</p>
        </div>
    </div>
</div>
