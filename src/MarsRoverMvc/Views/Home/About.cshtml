@{
    ViewData["Title"] = "About";
}

<div class="page-header">
    <h1 class="page-title">About Mars Rover Simulator</h1>
    <p class="page-description">Understanding this application</p>
</div>

<div class="card">
    <h2 class="card-title">Project Overview</h2>
    <p style="margin-bottom: 15px; line-height: 1.6;">
        The Mars Rover Simulator is an ASP.NET Core MVC application that solves the NASA Mars Rover coding challenge.
        A squad of robotic rovers are landed on a plateau on Mars and must navigate the terrain using simple commands.
    </p>
</div>

<div class="card">
    <h2 class="card-title">Architecture</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        <div>
            <h3 style="color: #4CAF50; margin-bottom: 15px;">Web API (ASP.NET Core)</h3>
            <ul style="margin-left: 20px; line-height: 1.8;">
                <li>RESTful endpoints for simulation</li>
                <li>Core rover movement logic</li>
                <li>History persistence (JSON-based)</li>
                <li>Screenshot storage</li>
            </ul>
        </div>
        <div>
            <h3 style="color: #4CAF50; margin-bottom: 15px;">MVC Application</h3>
            <ul style="margin-left: 20px; line-height: 1.8;">
                <li>User-friendly UI</li>
                <li>Plateau visualization</li>
                <li>Path tracking and display</li>
                <li>History browsing</li>
            </ul>
        </div>
    </div>
</div>

<div class="card">
    <h2 class="card-title">Technologies Used</h2>
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
        <div style="padding: 15px; background: #f5f5f5; border-radius: 6px;">
            <strong>.NET 10</strong>
            <p style="margin-top: 5px; color: #666; font-size: 13px;">Latest ASP.NET Core framework</p>
        </div>
        <div style="padding: 15px; background: #f5f5f5; border-radius: 6px;">
            <strong>C#</strong>
            <p style="margin-top: 5px; color: #666; font-size: 13px;">Modern object-oriented programming</p>
        </div>
        <div style="padding: 15px; background: #f5f5f5; border-radius: 6px;">
            <strong>RESTful API</strong>
            <p style="margin-top: 5px; color: #666; font-size: 13px;">Service-oriented architecture</p>
        </div>
        <div style="padding: 15px; background: #f5f5f5; border-radius: 6px;">
            <strong>JSON Storage</strong>
            <p style="margin-top: 5px; color: #666; font-size: 13px;">File-based history persistence</p>
        </div>
    </div>
</div>

<div class="card">
    <h2 class="card-title">Key Features</h2>
    <ul style="margin-left: 20px; line-height: 2;">
        <li>✅ Multi-rover simulation on configurable plateaus</li>
        <li>✅ Real-time plateau visualization with path tracking</li>
        <li>✅ Complete simulation history with searchable records</li>
        <li>✅ Screenshot capture and storage</li>
        <li>✅ Clean separation of concerns (MVC + API)</li>
        <li>✅ Fully commented codebase for learning</li>
    </ul>
</div>
