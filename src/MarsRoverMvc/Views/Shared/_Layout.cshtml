@{
    var path = Context.Request.Path.Value?.ToLower() ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link href="~/css/root.css" rel="stylesheet" type="text/css">
</head>

<body>
<div class="container">
    <!-- Sidebar -->
    <nav class="nav-container">
        <header class="logo">
            <div class="logo-icon">
                <img src="~/images/icons/rover-icon.svg" alt="Icon" width="50" height="50"/>
            </div>
            <div class="logo-text">
                <h3 class="logo-title">MARS ROVER SIMULATOR</h3>
            </div>
        </header>

        <hr class="divider"/>

        <ul>
            <li class="nav-item @(path.Contains("/home") ? "active" : "")">
                <a href="/home" class="nav-link">
                    <span class="nav-icon">
                        <img src="~/images/icons/about-icon.svg" alt="Icon" width="24" height="24"/>
                    </span>
                    <p>About</p>
                </a>
            </li>

            <li class="nav-item @(path.Contains("/simulation") ? "active" : "")">
                <a href="/Simulation/Index" class="nav-link">
                    <img class="nav-icon" src="~/images/icons/simulation-icon.svg" alt="Icon" width="24" height="24"/>
                    <p>Simulations</p>
                </a>
            </li>

            <li class="nav-item @(path.Contains("/history") ? "active" : "")">
                <a href="/History/Index" class="nav-link">
                    <span class="nav-icon">
                        <img src="~/images/icons/history-icon.svg" alt="Icon" width="24" height="24"/>
                    </span>
                    <p>History</p>
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main class="page-container">
        @RenderBody()
    </main>
</div>
</body>

</html>
