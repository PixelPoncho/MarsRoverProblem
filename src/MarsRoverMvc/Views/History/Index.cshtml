@model MarsRoverMvc.Models.HistoryViewModel

@{
    ViewData["Title"] = "Simulation History";
}


<section class="card history-page">
    <div class="card-header">
        <h1>Simulation History</h1>
    </div>

    <div class="card-body">
        @if (Model.Simulations == null || Model.Simulations.Count == 0)
        {
            <div class="flex">
                <div class="border-container">
                    <h3>No History Found</h3>
                    <p>Run a simulation to create a new history entry.</p>
                    <a href="/Simulation/Index" class="btn btn-primary" role="button">
                        <p>Start New Simulation</p>
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="pagination">
                <p class="pagination-btn disabled">‹</p>
                <p class="pagination-btn active">1</p>
                <p class="pagination-btn">2</p>
                <p >...</p>
                <p class="pagination-btn disabled">4</p>
                <p class="pagination-btn disabled">›</p >
            </div>

            <table class="history-table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Plateau Size</th>
                    <th>Instructions</th>
                    <th>Results</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
                </thead>

                <tbody>
                @foreach (var simulation in Model.Simulations)
                {
                    <tr>
                        <td>
                            <div class="tooltip-wrapper">
                                <code>
                                    @simulation.SimulationId.Substring(0, 8)...
                                </code>
                                <p class="tooltip-text id-tooltip">
                                    @simulation.SimulationId
                                </p>
                            </div>
                        </td>
                        <td>@simulation.PlateauSize</td>
                        @foreach (var result in simulation.Results)
                        {
                            <td>
                                <div class="tooltip-wrapper">
                                    <strong>Rover @result.RoverId:</strong>
                                    @if (@result.Commands.Length > 20)
                                    {
                                        <p>
                                            @result.Commands.Substring(0, 20)...
                                        </p>
                                        <p class="tooltip-text">
                                            @result.Commands
                                        </p>
                                    }
                                    else
                                    {
                                        @result.Commands
                                    }
                                </div>
                            </td>

                            <td>
                                <div >
                                    <strong>Rover @result.RoverId:</strong> (@result.FinalX, @result.FinalY) @result.FinalDirection
                                </div>
                            </td>
                        }
                        <td>
                            <p>@simulation.ExecutedAt.ToString("yyyy-MM-dd HH:mm")</p>
                        </td>
                        <td>
                            <button class="btn btn-secondary btn-small" onclick="viewDetails('@simulation.SimulationId')">
                                View
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</section>

<script>
    function viewDetails(simulationId) {
        alert('Simulation ID: ' + simulationId + '\n\nDetailed view coming soon!');
    }
</script>
