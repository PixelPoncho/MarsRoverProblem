@model MarsRoverMvc.Models.SimulationResultViewModel

@{
    ViewData["Title"] = "Simulation Results";
}


<div class="simulation-grid">

    <!-- Plateau Visualization -->
    <section class="card">
        <div class="card-header">
            <h1>Plateau Visualization</h1>
        </div>

        <div class="card-body">

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
                <div class="form-group">
                    <label class="form-label" for="PlateauMaxX">Plateau Width (Max X)</label>
                    <input type="number" id="PlateauMaxX" name="PlateauMaxX" value="@Model.PlateauMaxX"
                           min="1" max="50" class="form-input" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="PlateauMaxY">Plateau Height (Max Y)</label>
                    <input type="number" id="PlateauMaxY" name="PlateauMaxY" value="@Model.PlateauMaxY"
                           min="1" max="50" class="form-input" required>
                </div>
            </div>

            <div id="plateauContainer" style="display: flex; justify-content: center; margin: 30px 0;">
                <canvas id="plateauCanvas" width="500" height="500" style="border: 2px solid #ddd; background: #f0f0f0; border-radius: 8px;"></canvas>
            </div>

            <input type="hidden" id="simulationId" value="@Model.SimulationId">
        </div>
    </section>

    <div>
        <section class="card">
            <div class="card-header">
                <h3>Legend</h3>
            </div>

            <div class="card-body">
                legend
            </div>
        </section>

        <section class="card">
            <div class="card-header">
                <h3>Results</h3>
            </div>

            <div class="card-body">
                results
            </div>
        </section>

    </div>
</div>


<!-- Results Table -->
<section class="card">
    <div class="card-header">
        <h3>Rover(s) Output</h3>
    </div>

    <div class="card-body">

        <table>
            <thead>
            <tr>
                <th>#</th>
                <th>Final Position (X Y D)</th>
                <th>Commands</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var result in Model.Results)
            {
                <tr>
                    <td>
                        <strong>Rover @result.RoverId</strong>
                    </td>
                    <td>
                        <strong>@result.FinalX @result.FinalY @result.FinalDirection</strong>
                    </td>
                    <td>
                        <code>@result.Commands</code>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <!-- Actions -->
        <div style="display: flex; gap: 10px; margin-top: 30px;">
            <a href="/Simulation/Index" class="btn btn-primary">
                <span>⚙️</span>
                <span>Run Another Simulation</span>
            </a>
            <a href="/History/Index" class="btn btn-secondary">
                <span>📚</span>
                <span>View History</span>
            </a>
        </div>
    </div>
</section>


<script>
    // Data passed to the visualization script
    // IMPORTANT: Using proper JSON serialization with camelCase property names
    // This ensures JavaScript can access properties with standard naming convention
    const plateauData = {
        maxX: @Model.PlateauMaxX,
        maxY: @Model.PlateauMaxY,
        rovers: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.Results,
                    new System.Text.Json.JsonSerializerOptions
                    {
                        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                    }
                ))
    };

    // Draw the plateau when the page loads
    window.addEventListener('load', function () {
        drawPlateau();
    });

    function drawPlateau() {
        const canvas = document.getElementById('plateauCanvas');
        const ctx = canvas.getContext('2d');

        // Canvas dimensions
        const padding = 40;
        const usableWidth = canvas.width - (padding * 2);
        const usableHeight = canvas.height - (padding * 2);
        const cellWidth = usableWidth / plateauData.maxX;
        const cellHeight = usableHeight / plateauData.maxY;

        // Clear canvas
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Draw grid
        ctx.strokeStyle = '#ddd';
        ctx.lineWidth = 1;

        // Vertical lines
        for (let x = 0; x <= plateauData.maxX; x++) {
            const xPos = padding + (x * cellWidth);
            ctx.beginPath();
            ctx.moveTo(xPos, padding);
            ctx.lineTo(xPos, canvas.height - padding);
            ctx.stroke();
        }

        // Horizontal lines
        for (let y = 0; y <= plateauData.maxY; y++) {
            const yPos = canvas.height - padding - (y * cellHeight);
            ctx.beginPath();
            ctx.moveTo(padding, yPos);
            ctx.lineTo(canvas.width - padding, yPos);
            ctx.stroke();
        }

        // Draw coordinate labels
        ctx.fillStyle = '#999';
        ctx.font = '12px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';

        for (let x = 0; x <= plateauData.maxX; x++) {
            const xPos = padding + (x * cellWidth);
            ctx.fillText(x, xPos, 20);
        }

        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        for (let y = 0; y <= plateauData.maxY; y++) {
            const yPos = canvas.height - padding - (y * cellHeight);
            ctx.fillText(y, padding - 10, yPos);
        }

        // Draw rovers and their paths
        // Colors for different rovers
        const colors = ['#FF6B6B', '#4ECDC4', '#45B7D1', '#FFA07A'];

        plateauData.rovers.forEach((rover, index) => {
            const color = colors[index % colors.length];

            // Draw path
            // IMPORTANT: Check for 'path' property (now in camelCase)
            if (rover.path && rover.path.length > 0) {

                ctx.strokeStyle = color;
                ctx.globalAlpha = 0.5;
                ctx.lineWidth = 2;
                ctx.beginPath();

                rover.path.forEach((pos, i) => {
                    const coords = pos.split(' ');
                    const x = parseInt(coords[0]);
                    const y = parseInt(coords[1]);

                    const xPos = padding + (x * cellWidth) + (cellWidth / 2);
                    const yPos = canvas.height - padding - (y * cellHeight) - (cellHeight / 2);

                    if (i === 0) {
                        ctx.moveTo(xPos, yPos);
                    } else {
                        ctx.lineTo(xPos, yPos);
                    }
                });

                ctx.stroke();
                ctx.globalAlpha = 1;
            } else {
                console.warn(`No path data for rover ${index}`);
            }

            // Draw start position (green S)
            if (rover.path && rover.path.length > 0) {
                const startCoords = rover.path[0].split(' ');
                const startX = parseInt(startCoords[0]);
                const startY = parseInt(startCoords[1]);

                const xPos = padding + (startX * cellWidth) + (cellWidth / 2);
                const yPos = canvas.height - padding - (startY * cellHeight) - (cellHeight / 2);

                // Draw green circle for start
                ctx.fillStyle = '#4CAF50';
                ctx.beginPath();
                ctx.arc(xPos, yPos, 8, 0, Math.PI * 2);
                ctx.fill();

                // Draw 'S' text
                ctx.fillStyle = '#fff';
                ctx.font = 'bold 12px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('S', xPos, yPos);
            }

            // Draw final position (colored circle with rover number)
            const finalXPos = padding + (rover.finalX * cellWidth) + (cellWidth / 2);
            const finalYPos = canvas.height - padding - (rover.finalY * cellHeight) - (cellHeight / 2);

            ctx.fillStyle = color;
            ctx.beginPath();
            ctx.arc(finalXPos, finalYPos, 10, 0, Math.PI * 2);
            ctx.fill();

            // Draw rover number in circle
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 14px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText((index + 1), finalXPos, finalYPos);
        });
    }
</script>
