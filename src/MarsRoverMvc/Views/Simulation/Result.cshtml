@model MarsRoverMvc.Models.SimulationResultViewModel

@{
    ViewData["Title"] = "Simulation Results";
}


<div class="simulation-grid">
    <!-- Plateau Visualization -->
    <section class="card">
        <div class="card-header">
            <h1>Plateau Visualization</h1>
        </div>

        <div class="card-body">

            <div class="grid grid-2" style=" gap: 20px; margin-bottom: 30px;">
                <div class="form-group">
                    <label class="form-label" for="PlateauMaxX">Plateau Width (Max X)</label>
                    <input type="number" id="PlateauMaxX" name="PlateauMaxX" value="@Model.PlateauMaxX"
                           min="1" max="50" class="form-input" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="PlateauMaxY">Plateau Height (Max Y)</label>
                    <input type="number" id="PlateauMaxY" name="PlateauMaxY" value="@Model.PlateauMaxY"
                           min="1" max="50" class="form-input" required>
                </div>
            </div>

            <div id="plateauContainer"
                 style="display: flex; justify-content: center; margin: 30px 0; width: 100%;">
                <canvas id="plateauCanvas"
                        style="width: 100%; height: 100%; border: 2px solid #ddd; border-radius: 8px;">
                </canvas>
            </div>
            <div id="tooltip"
                 style="position:absolute; background:#333; color:#fff; padding:6px 10px;
            font-size:12px; border-radius:6px; pointer-events:none;
            display:none;">
            </div>

            <input type="hidden" id="simulationId" value="@Model.SimulationId">
        </div>
    </section>

    <div>
        <section class="card legend-section">
            <div class="card-header">
                <h2>Legend</h2>
            </div>

            <div class="card-body">
                <div class="legend-item">
                    <div class="legend-icon start">S1</div>
                    <p class="legend-label">Start Position</p>
                </div>

                <div class="legend-item">
                    <div class="legend-icon finish">F1</div>
                    <p class="legend-label">Final Position</p>
                </div>

                <div class="legend-item">
                    <div class="legend-line"></div>
                    <p class="legend-label">Rover Path</p>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-header">
                <h2>Results</h2>
            </div>

            <div class="card-body">
                <table>
                    <thead>
                    <tr>
                        <th>#</th>
                        <th>Final Position</th>
                        <th>Commands</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var result in Model.Results)
                    {
                        <tr>
                            <td>
                                @result.RoverId
                            </td>
                            <td>
                                (@result.FinalX, @result.FinalY) @result.FinalDirection
                            </td>
                            <td>
                                @result.Commands
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>


<!-- Results Table -->
<div class="simulation-grid">
    <section class="card">
        <div class="card-header">
            <h2>Rover(s) Input</h2>
        </div>

        <div class="card-body">
            <!-- Actions -->
            <div style="display: flex; gap: 10px; margin-top: 30px;">
                <a href="/Simulation/Index" class="btn btn-primary">
                    <span>⚙️</span>
                    <span>Run Another Simulation</span>
                </a>
                <a href="/History/Index" class="btn btn-secondary">
                    <span>📚</span>
                    <span>View History</span>
                </a>
            </div>
        </div>
    </section>
</div>


<script>
    // The following is to track the mouse position for tooltips and interactivity on the plateau visualization
    let mouse = { x: 0, y: 0 };

    const canvas = document.getElementById('plateauCanvas');
    const tooltip = document.getElementById('tooltip');

    canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();

        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;

        updateTooltip(e);
    });

    canvas.addEventListener('mouseleave', () => {
        tooltip.style.display = 'none';
    });

    function updateTooltip(e) {
        const canvas = document.getElementById('plateauCanvas');
        const tooltip = document.getElementById('tooltip');

        const padding = 40;

        const usableWidth = canvas.width - (padding * 2);
        const usableHeight = canvas.height - (padding * 2);

        const cellWidth = usableWidth / plateauData.maxX;
        const cellHeight = usableHeight / plateauData.maxY;

        const gridX = Math.floor((mouse.x - padding) / cellWidth);
        const gridY = Math.floor((canvas.height - mouse.y - padding) / cellHeight);


        if (
            gridX >= 0 && gridX <= plateauData.maxX &&
            gridY >= 0 && gridY <= plateauData.maxY
        ) {
            tooltip.style.display = 'block';
            tooltip.style.left = `${e.clientX + window.scrollX + 10}px`;
            tooltip.style.top = `${e.clientY + window.scrollY + 10}px`;
            tooltip.innerText = `X: ${gridX}, Y: ${gridY}`;
        } else {
            tooltip.style.display = 'none';
        }
    }

    // Data passed to the visualization script
    // IMPORTANT: Using proper JSON serialization with camelCase property names
    // This ensures JavaScript can access properties with standard naming convention
    const plateauData = {
        maxX: @Model.PlateauMaxX,
        maxY: @Model.PlateauMaxY,
        rovers: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.Results,
                    new System.Text.Json.JsonSerializerOptions
                    {
                        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                    }
                ))
    };

    ///////////////////////////////////


    /// Event Listeners
    // Draw the plateau when the page loads
    // Save screenshot of the plateau visualization once loads
    window.addEventListener('load', function () {
        drawPlateau();
        captureScreenshot();
    });

    // Redraw the plateau when the window is resized to maintain responsiveness, specifically of that of the tooltips
    window.addEventListener('resize', () => {
        drawPlateau();
    });

    ///////////////////////////////////

    function drawPlateau() {
        const canvas = document.getElementById('plateauCanvas');
        const ctx = canvas.getContext('2d');

        // Allows us to dynamically size the canvas based on container dimensions
        const container = document.getElementById('plateauContainer');

        // Match display size
        const rect = container.getBoundingClientRect();

        // Set actual drawing resolution
        canvas.width = rect.width;
        canvas.height = rect.height;

        // Canvas dimensions
        const padding = 40;
        const usableWidth = canvas.width - (padding * 2);
        const usableHeight = canvas.height - (padding * 2);
        const cellWidth = usableWidth / plateauData.maxX;
        const cellHeight = usableHeight / plateauData.maxY;

        // Max dimensions for dynamic label spacing
        const maxDimension = Math.max(plateauData.maxX, plateauData.maxY);
        let labelStep = maxDimension > 40 ? 10 : maxDimension > 20 ? 5 : 1;

        // Clear canvas
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Draw grid
        ctx.strokeStyle = '#ddd';
        ctx.lineWidth = 1;

        // Vertical lines
        for (let x = 0; x <= plateauData.maxX; x++) {
            const xPos = padding + (x * cellWidth);
            ctx.beginPath();
            ctx.moveTo(xPos, padding);
            ctx.lineTo(xPos, canvas.height - padding);
            ctx.stroke();
        }

        // Horizontal lines
        for (let y = 0; y <= plateauData.maxY; y++) {
            const yPos = canvas.height - padding - (y * cellHeight);
            ctx.beginPath();
            ctx.moveTo(padding, yPos);
            ctx.lineTo(canvas.width - padding, yPos);
            ctx.stroke();
        }

        // Draw coordinate labels
        ctx.fillStyle = '#999';
        ctx.font = '12px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';


        for (let x = 0; x <= plateauData.maxX; x++) {
            if (x % labelStep !== 0) continue;

            const xPos = padding + (x * cellWidth);
            const yPos = canvas.height - padding + 16; // slightly below grid

            ctx.fillText(x, xPos, yPos);
        }

        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        for (let y = 0; y <= plateauData.maxY; y++) {
            if (y % labelStep !== 0) continue;

            const yPos = canvas.height - padding - (y * cellHeight);
            ctx.fillText(y, padding - 16, yPos);
        }

        // Draw rovers and their paths
        // Colors for different rovers
        const colors = generateColors(plateauData.rovers.length);
        const size = 20;

        plateauData.rovers.forEach((rover, index) => {
            const color = colors[index % colors.length];

            // Draw path
            // IMPORTANT: Check for 'path' property (now in camelCase)
            if (rover.path && rover.path.length > 0) {

                ctx.strokeStyle = color;
                ctx.globalAlpha = 0.7;
                ctx.lineWidth = 8;       // path thickness
                ctx.setLineDash([8, 6]); // dash pattern (8px line, 6px gap)               
                ctx.beginPath();

                rover.path.forEach((pos, i) => {
                    const coords = pos.split(' ');
                    const x = parseInt(coords[0]);
                    const y = parseInt(coords[1]);

                    const xPos = padding + (x * cellWidth);
                    const yPos = canvas.height - padding - (y * cellHeight);

                    if (i === 0) {
                        ctx.moveTo(xPos, yPos);
                    } else {
                        ctx.lineTo(xPos, yPos);
                    }
                });

                ctx.stroke();
                ctx.globalAlpha = 1;
            } else {
                console.warn(`No path data for rover ${index}`);
            }

            // Draw start position
            if (rover.path && rover.path.length > 0) {
                const startCoords = rover.path[0].split(' ');
                const startX = parseInt(startCoords[0]);
                const startY = parseInt(startCoords[1]);

                const xPos = padding + (startX * cellWidth);
                const yPos = canvas.height - padding - (startY * cellHeight);

                ctx.fillStyle = color;
                ctx.fillRect(
                    xPos - size / 2,
                    yPos - size / 2,
                    size,
                    size
                );

                // Draw 'S' + rover number centered
                ctx.fillStyle = '#fff';
                ctx.font = 'bold 12px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('S' + (index + 1), xPos, yPos);
            }

            // Draw final position
            const finalXPos = padding + (rover.finalX * cellWidth);
            const finalYPos = canvas.height - padding - (rover.finalY * cellHeight);

            // Draw rover square (finish)
            ctx.fillStyle = color;
            ctx.fillRect(
                finalXPos - size / 2,
                finalYPos - size / 2,
                size,
                size
            );

            // Draw F + rover number centered
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 14px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('F' + (index + 1), finalXPos, finalYPos);
        });
    }

    function generateColors(count) {
        const colors = [];
        const baseHue = 175; // blue-ish green

        for (let i = 0; i < count; i++) {
            const hue = (baseHue + (360 / count) * i) % 360;
            colors.push(`hsl(${hue}, 50%, 55%)`);
        }

        return colors;
    }
</script>

<script>
    function captureScreenshot() {
        const element = document.getElementById("plateauCanvas");
        if (!element) {
            alert('Element not found');
            return;
        }

        html2canvas(element, { backgroundColor: '#ffffff' }).then(canvas => {
            const base64Image = canvas.toDataURL('image/png');
            saveScreenshot(base64Image);
        }).catch(err => {
            alert('Error capturing screenshot: ' + err);
        });
    }

    function saveScreenshot(base64Image) {
        const simulationId = document.getElementById('simulationId')?.value;
        if (!simulationId) {
            alert('Simulation ID not found');
            return;
        }

        fetch(`https://localhost:5002/api/rover/save-screenshot?simulationId=${simulationId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ imageBase64: base64Image })
        })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                alert('Screenshot saved successfully!');
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error saving screenshot');
            });
    }
</script>
