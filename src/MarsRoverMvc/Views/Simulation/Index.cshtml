@model MarsRoverMvc.Models.SimulationResultViewModel

@{
    ViewData["Title"] = "Simulation Results";
}


<div class="flex-container">
    <!-- Plateau Visualization -->
    <section class="card visualization">
        <div class="card-header">
            <h1>Plateau Visualization</h1>
        </div>

        <div class="card-body">
            <div>
                <p class="instruction-text">
                    Define the dimensions of the plateau.
                </p>
                <p>
                    <small>Please note the canvas will only update on page load, so re-run the simulation to see any changes reflected in the visualization.</small>
                </p>
            </div>

            <div class="flex">
                <div class="form-group">
                    <label class="form-label" for="PlateauMaxX">
                        <bold class="bold">Plateau Width</bold> <small>(Max X: 50)</small>
                    </label>
                    <input type="number" id="PlateauMaxX" name="PlateauMaxX" value="@Model.PlateauMaxX"
                           min="1" max="50" class="form-input" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="PlateauMaxY">
                        <bold class="bold">Plateau Height</bold> <small>(Max Y: 50)</small>
                    </label>
                    <input type="number" id="PlateauMaxY" name="PlateauMaxY" value="@Model.PlateauMaxY"
                           min="1" max="50" class="form-input" required>
                </div>
            </div>

            <div id="plateauContainer"
                 style="display: flex; justify-content: center; margin: 30px 0; width: 100%;">
                <canvas id="plateauCanvas"
                        style="width: 100%; height: 100%; border: 2px solid #ddd; border-radius: 8px;">
                </canvas>
            </div>
            <div id="tooltip"
                 style="position:absolute; background:#333; color:#fff; padding:6px 10px;
            font-size:12px; border-radius:6px; pointer-events:none;
            display:none;">
            </div>

            <input type="hidden" id="simulationId" value="@Model.SimulationId">
        </div>
    </section>

    <div>
        @* Legend Section *@
        <section class="card legend-section">
            <div class="card-header">
                <h2>Legend</h2>
            </div>

            <div class="card-body">
                <div class="legend-item">
                    <div class="legend-icon start">S#</div>
                    <p class="legend-label">Rover's Start Position</p>
                </div>

                <div class="legend-item">
                    <div class="legend-icon finish">F#</div>
                    <p class="legend-label">Rover's Final Position</p>
                </div>

                <div class="legend-item">
                    <div class="legend-line"></div>
                    <p class="legend-label">Rover Path</p>
                </div>

                <p>
                    <small> Please note each Rover should have a different colour and number associated with it</small>
                </p>
            </div>
        </section>

        @* Results Table *@
        <section class="card results-section">
            <div class="card-header">
                <h2>Results</h2>
            </div>

            <div class="card-body">
                <table>
                    <thead>
                    <tr>
                        <th>#</th>
                        <th>Final Position</th>
                        <th>Commands</th>
                    </tr>
                    </thead>

                    <tbody>
                    @if (Model.Results == null || Model.Results.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="no-results">
                                <p>
                                    <small>
                                        No results to display. Please run a simulation.
                                    </small>
                                </p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var result in Model.Results)
                        {
                            <tr>
                                <td>
                                    @result.RoverId
                                </td>
                                <td>
                                    (@result.FinalX, @result.FinalY) @result.FinalDirection
                                </td>
                                <td>
                                    @result.Commands
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>

                <a href="/History/Index" class="btn btn-secondary history-btn">
                    <p>View History</p>
                </a>
            </div>
        </section>
    </div>
</div>


<!-- Rover Table -->
<div class="rover-section-container">
    <section class="card rover">
        <div class="card-header">
            <h2>Rover(s)</h2>
        </div>

        <div class="card-body">
            <form method="post" action="/Simulation/Run" id="simulationForm">
                <input type="hidden" id="HiddenPlateauMaxX" name="PlateauMaxX"
                       min="1" max="50">
                <input type="hidden" id="HiddenPlateauMaxY" name="PlateauMaxY"
                       min="1" max="50">

                <p class="instruction-text">
                    Add rovers to the plateau! Each rover will need a starting position, starting orientation, and a series of commands.
                </p>
                <p>
                    <small>Please note that it currently not possible to traverse out of bounds, as a result, such instructions will be disregarded.</small>
                </p>

                <div id="rover-entries-section">
                    @if (Model.InputRovers != null && Model.InputRovers.Count > 0)
                    {
                        @for (int i = 0; i < Model.InputRovers.Count; i++)
                        {
                            <div class="rover-row">
                                <h4>Rover @(i + 1)</h4>

                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">Start X</label>
                                        <input type="number" name="Rovers[@i].StartX" value="@Model.InputRovers[i].StartX"
                                               min="0" max="50" class="form-input" required>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">Start Y</label>
                                        <input type="number" name="Rovers[@i].StartY" value="@Model.InputRovers[i].StartY"
                                               min="0" max="50" class="form-input" required>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">Direction</label>
                                        <select name="Rovers[@i].StartDirection" class="form-select" required>
                                            <option value="N" @(Model.InputRovers[i].StartDirection == "N" ? "selected" : "")>North (N)</option>
                                            <option value="E" @(Model.InputRovers[i].StartDirection == "E" ? "selected" : "")>East (E)</option>
                                            <option value="S" @(Model.InputRovers[i].StartDirection == "S" ? "selected" : "")>South (S)</option>
                                            <option value="W" @(Model.InputRovers[i].StartDirection == "W" ? "selected" : "")>West (W)</option>
                                        </select>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">Commands</label>

                                        <input type="text" name="Rovers[@i].Commands" value="@Model.InputRovers[i].Commands"
                                               placeholder="e.g., LMLMLMLMM" class="form-input" required
                                               pattern="[LRM]*" title="Only L, R, M allowed">
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Actions -->
                <div class="action-container">
                    <div class="add-remove-rover-container">
                        <button type="button" class="btn btn-secondary" onclick="addRover()">
                            + Add Rover
                        </button>
                        <button type="button" class="btn btn-danger" onclick="removeAllRovers()">
                            Remove All
                        </button>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <span>▶</span>
                        <span>Run Simulation</span>
                    </button>
                </div>
            </form>

        </div>
    </section>
</div>


<script>
    // Data passed to the visualization script
    const plateauData = {
        maxX: @Model.PlateauMaxX,
        maxY: @Model.PlateauMaxY,
        rovers: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.Results,
                    new System.Text.Json.JsonSerializerOptions
                    {
                        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
                    }
                ))
    };

    ///////////////////////////////////

    /// EVENT LISTENERS
    // Draw the plateau when the page loads
    // Save screenshot of the plateau visualization once loads
    window.addEventListener('load', function () {
        removeAllRovers();
        drawPlateau();
        captureScreenshot();
    });

    // Redraw the plateau when the window is resized to maintain responsiveness, specifically of that of the tooltips
    window.addEventListener('resize', () => {
        drawPlateau();
    });

    ///////////////////////////////////
    // @* Minor form logic when user submits *@
    document.getElementById('simulationForm').addEventListener('submit', (e) => {
        // Before submitting, adding hidden inputs for plateau dimensions
        document.getElementById('HiddenPlateauMaxX').value = document.getElementById('PlateauMaxX').value;
        document.getElementById('HiddenPlateauMaxY').value = document.getElementById('PlateauMaxY').value;
    });

    ///////////////////////////////////
    // @* Minor form logic to ensure users dont enter values larger than expected *@
    document.getElementById('PlateauMaxX')
        .addEventListener('input', (e) => enforcePlateauMax(e, 50));

    document.getElementById('PlateauMaxY')
        .addEventListener('input', (e) => enforcePlateauMax(e, 50));

    function enforcePlateauMax(e, max) {
        const value = Number(e.target.value);

        if (value > max) {
            e.target.value = max;
        }
    }

    document.getElementById('PlateauMaxX')
        .addEventListener('input', enforceAllRoverBounds);

    document.getElementById('PlateauMaxY')
        .addEventListener('input', enforceAllRoverBounds);

    document.getElementById('rover-entries-section')
        .addEventListener('input', (e) => {
            if (e.target.name?.includes('StartX') || e.target.name?.includes('StartY')) {
                enforceAllRoverBounds();
            }
        });

    document.getElementById('rover-entries-section')
        .addEventListener('blur', (e) => {
            if (e.target.name?.includes('StartX') || e.target.name?.includes('StartY')) {
                enforceAllRoverBounds();
            }
        }, true);

    function clamp(val, min, max) {
        if (isNaN(val)) return min;
        return Math.max(min, Math.min(max, val));
    }

    function enforceAllRoverBounds() {
        const maxX = Number(document.getElementById('PlateauMaxX').value);
        const maxY = Number(document.getElementById('PlateauMaxY').value);

        document.querySelectorAll('.rover-row').forEach(row => {
            const xInput = row.querySelector('input[name*="StartX"]');
            const yInput = row.querySelector('input[name*="StartY"]');

            if (xInput) {
                const val = Number(xInput.value);
                xInput.value = clamp(val, 0, maxX);
                xInput.max = maxX;
            }

            if (yInput) {
                const val = Number(yInput.value);
                yInput.value = clamp(val, 0, maxY);
                yInput.max = maxY;
            }
        });
    }

    // Keep input attributes in sync
    function syncMinMaxAttributes() {
        const maxX = Number(plateauX.value);
        const maxY = Number(plateauY.value);

        document.querySelectorAll('.rover-row').forEach(row => {
            const x = row.querySelector('input[name*="StartX"]');
            const y = row.querySelector('input[name*="StartY"]');

            if (x) {
                x.min = 0;
                x.max = maxX;
            }

            if (y) {
                y.min = 0;
                y.max = maxY;
            }
        });
    }

    document.getElementById('PlateauMaxX')
        .addEventListener('input', (e) => enforcePlateauMax(e, 50));

    document.getElementById('PlateauMaxY')
        .addEventListener('input', (e) => enforcePlateauMax(e, 50));

    document.getElementById('PlateauMaxX')
        .addEventListener('input', (e) => clampValue(0, plateauX.value));

    document.getElementById('PlateauMaxY')
        .addEventListener('input', (e) => clampValue(0, plateauY.value));


    ///////////////////////////////////
    // @* Logic for rendering tooltip on the plateau canvas *@
    let mouse = { x: 0, y: 0 };

    const canvas = document.getElementById('plateauCanvas');
    const tooltip = document.getElementById('tooltip');

    canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();

        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;

        updateTooltip(e);
    });

    canvas.addEventListener('mouseleave', () => {
        tooltip.style.display = 'none';
    });

    function updateTooltip(e) {
        const canvas = document.getElementById('plateauCanvas');
        const tooltip = document.getElementById('tooltip');

        const padding = 40;

        const usableWidth = canvas.width - (padding * 2);
        const usableHeight = canvas.height - (padding * 2);

        const cellWidth = usableWidth / plateauData.maxX;
        const cellHeight = usableHeight / plateauData.maxY;

        const gridX = Math.floor((mouse.x - padding) / cellWidth);
        const gridY = Math.floor((canvas.height - mouse.y - padding) / cellHeight);


        if (
            gridX >= 0 && gridX <= plateauData.maxX &&
            gridY >= 0 && gridY <= plateauData.maxY
        ) {
            tooltip.style.display = 'block';
            tooltip.style.left = `${e.clientX + window.scrollX + 10}px`;
            tooltip.style.top = `${e.clientY + window.scrollY + 10}px`;
            tooltip.innerText = `X: ${gridX}, Y: ${gridY}`;
        } else {
            tooltip.style.display = 'none';
        }
    }

    ///////////////////////////////////
    //@* Logic for drawing Plateau and relevant rover + it's paths *@
    function drawPlateau() {
        const canvas = document.getElementById('plateauCanvas');
        const ctx = canvas.getContext('2d');

        // Allows us to dynamically size the canvas based on container dimensions
        const container = document.getElementById('plateauContainer');

        // Match display size
        const rect = container.getBoundingClientRect();

        // Set actual drawing resolution
        canvas.width = rect.width;
        canvas.height = rect.height;

        // Canvas dimensions
        const padding = 40;
        const usableWidth = canvas.width - (padding * 2);
        const usableHeight = canvas.height - (padding * 2);
        const cellWidth = usableWidth / plateauData.maxX;
        const cellHeight = usableHeight / plateauData.maxY;

        // Max dimensions for dynamic label spacing
        const maxDimension = Math.max(plateauData.maxX, plateauData.maxY);
        let labelStep = maxDimension > 40 ? 10 : maxDimension > 20 ? 5 : 1;

        // Clear canvas
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Draw grid
        ctx.strokeStyle = '#ddd';
        ctx.lineWidth = 1;

        // Vertical lines
        for (let x = 0; x <= plateauData.maxX; x++) {
            const xPos = padding + (x * cellWidth);
            ctx.beginPath();
            ctx.moveTo(xPos, padding);
            ctx.lineTo(xPos, canvas.height - padding);
            ctx.stroke();
        }

        // Horizontal lines
        for (let y = 0; y <= plateauData.maxY; y++) {
            const yPos = canvas.height - padding - (y * cellHeight);
            ctx.beginPath();
            ctx.moveTo(padding, yPos);
            ctx.lineTo(canvas.width - padding, yPos);
            ctx.stroke();
        }

        // Draw coordinate labels
        ctx.fillStyle = '#999';
        ctx.font = '12px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';


        for (let x = 0; x <= plateauData.maxX; x++) {
            if (x % labelStep !== 0) continue;

            const xPos = padding + (x * cellWidth);
            const yPos = canvas.height - padding + 16; // slightly below grid

            ctx.fillText(x, xPos, yPos);
        }

        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        for (let y = 0; y <= plateauData.maxY; y++) {
            if (y % labelStep !== 0) continue;

            const yPos = canvas.height - padding - (y * cellHeight);
            ctx.fillText(y, padding - 16, yPos);
        }

        // Draw rovers and their paths
        // Colors for different rovers
        const colors = generateColors(plateauData.rovers.length);
        const size = 20;

        plateauData.rovers.forEach((rover, index) => {
            const color = colors[index % colors.length];

            // Draw path
            // IMPORTANT: Check for 'path' property (now in camelCase)
            if (rover.path && rover.path.length > 0) {

                ctx.strokeStyle = color;
                ctx.globalAlpha = 0.7;
                ctx.lineWidth = 8;       // path thickness
                ctx.setLineDash([8, 6]); // dash pattern (8px line, 6px gap)               
                ctx.beginPath();

                rover.path.forEach((pos, i) => {
                    const coords = pos.split(' ');
                    const x = parseInt(coords[0]);
                    const y = parseInt(coords[1]);

                    const xPos = padding + (x * cellWidth);
                    const yPos = canvas.height - padding - (y * cellHeight);

                    if (i === 0) {
                        ctx.moveTo(xPos, yPos);
                    } else {
                        ctx.lineTo(xPos, yPos);
                    }
                });

                ctx.stroke();
                ctx.globalAlpha = 1;
            } else {
                console.warn(`No path data for rover ${index}`);
            }

            // Draw start position
            if (rover.path && rover.path.length > 0) {
                const startCoords = rover.path[0].split(' ');
                const startX = parseInt(startCoords[0]);
                const startY = parseInt(startCoords[1]);

                const xPos = padding + (startX * cellWidth);
                const yPos = canvas.height - padding - (startY * cellHeight);

                ctx.fillStyle = color;
                ctx.fillRect(
                    xPos - size / 2,
                    yPos - size / 2,
                    size,
                    size
                );

                // Draw 'S' + rover number centered
                ctx.fillStyle = '#fff';
                ctx.font = 'bold 12px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('S' + (index + 1), xPos, yPos);
            }

            // Draw final position
            const finalXPos = padding + (rover.finalX * cellWidth);
            const finalYPos = canvas.height - padding - (rover.finalY * cellHeight);

            // Draw rover square (finish)
            ctx.fillStyle = color;
            ctx.fillRect(
                finalXPos - size / 2,
                finalYPos - size / 2,
                size,
                size
            );

            // Draw F + rover number centered
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 14px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('F' + (index + 1), finalXPos, finalYPos);
        });
    }

    function generateColors(count) {
        const colors = [];
        const baseHue = 175; // blue-ish green

        for (let i = 0; i < count; i++) {
            const hue = (baseHue + (360 / count) * i) % 360;
            colors.push(`hsl(${hue}, 50%, 55%)`);
        }

        return colors;
    }

    ///////////////////////////////////
    //@* Logic to adding or removing rover entries*@
    let roverCount = @(Model?.InputRovers?.Count ?? 0);

    function addRover() {
        const container = document.getElementById('rover-entries-section');
        const plateauX = document.getElementById('PlateauMaxX').value;
        const plateauY = document.getElementById('PlateauMaxY').value;

        const html = `
        <div class="rover-row">
            <h4>Rover ${roverCount + 1}</h4>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Start X</label>
                    <input type="number" name="Rovers[${roverCount}].StartX" value="0" min="0" max="50" class="form-input" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Start Y</label>
                    <input type="number" name="Rovers[${roverCount}].StartY" value="0" min="0" max="50" class="form-input" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Direction</label>
                    <select name="Rovers[${roverCount}].StartDirection" class="form-select" required>
                        <option value="N">North (N)</option>
                        <option value="E">East (E)</option>
                        <option value="S">South (S)</option>
                        <option value="W">West (W)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Commands</label>
                    <input type="text" name="Rovers[${roverCount}].Commands" value="" placeholder="e.g., LMLMLMLMM" class="form-input" required pattern="[LRM]*" title="Only L, R, M allowed">
                </div>

                <button type="button" class="btn btn-danger btn-small" onclick="removeRover(this)">
                    <img src="/images/icons/remove-icon.svg" alt="Remove Icon" width="20" height="20"/>
                </button>
            </div>
        </div>
        `;

        container.insertAdjacentHTML('beforeend', html);
        roverCount++;
    }

    function removeAllRovers() {
        const container = document.getElementById('rover-entries-section');

        if (!container) {
            console.error('rover-entries-section not found');
            return;
        }

        const roverRows = container.querySelectorAll('.rover-row');

        if (roverRows.length <= 1) {
            return; // nothing to remove
        }

        // Remove everything except the first rover
        for (let i = 1; i < roverRows.length; i++) {
            roverRows[i].remove();
        }

        // Reset roverCount to match the remaining structure
        roverCount = 1;

        reindexRovers();
    }

    function removeRover(button) {
        button.closest('.rover-row').remove();
        roverCount -= 1;
        reindexRovers()
    }

    function reindexRovers() {
        const rows = document.querySelectorAll('#rover-entries-section .rover-row');

        rows.forEach((row, index) => {
            const inputs = row.querySelectorAll('input, select');

            inputs.forEach(input => {
                if (!input.name) return;

                input.name = input.name.replace(/Rovers\[\d+\]/, `Rovers[${index}]`);
            });

            // Update rover label text (optional)
            const title = row.querySelector('h4');
            if (title) {
                title.textContent = `Rover ${index + 1}`;
            }
        });
    }

    ///////////////////////////////////
    // @* Logic pertaining to capturing screenshots *@
    function captureScreenshot() {
        const element = document.getElementById("plateauCanvas");
        if (!element) {
            alert('Element not found');
            return;
        }

        html2canvas(element, { backgroundColor: '#ffffff' }).then(canvas => {
            const base64Image = canvas.toDataURL('image/png');
            saveScreenshot(base64Image);
        }).catch(err => {
            alert('Error capturing screenshot: ' + err);
        });
    }

    function saveScreenshot(base64Image) {
        const simulationId = document.getElementById('simulationId')?.value;
        if (!simulationId) {
            return;
        }

        fetch(`https://localhost:5002/api/rover/save-screenshot?simulationId=${simulationId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ imageBase64: base64Image })
        })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error saving screenshot');
            });
    }
</script>