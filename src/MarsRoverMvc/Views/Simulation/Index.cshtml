@model MarsRoverMvc.Models.SimulationViewModel

@{
    ViewData["Title"] = "New Simulation";
}


<section class="card plateau-section">
    <h2 class="card-title">1. Plateau Size</h2>

    <form method="post" action="/Simulation/Run" id="simulationForm">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div class="form-group">
                <label class="form-label" for="PlateauMaxX">Plateau Width (Max X)</label>
                <input type="number" id="PlateauMaxX" name="PlateauMaxX" value="@Model.PlateauMaxX"
                       min="1" max="50" class="form-input" required>
            </div>
            <div class="form-group">
                <label class="form-label" for="PlateauMaxY">Plateau Height (Max Y)</label>
                <input type="number" id="PlateauMaxY" name="PlateauMaxY" value="@Model.PlateauMaxY"
                       min="1" max="50" class="form-input" required>
            </div>
        </div>

        <h2 class="card-title" style="margin-top: 40px;">2. Rovers</h2>
        <p style="color: #666; margin-bottom: 20px;">
            Add rovers to the plateau. Each rover needs a starting position and a series of commands.
        </p>

        <div id="roversContainer">
            @if (Model.Rovers != null && Model.Rovers.Count > 0)
            {
                @for (int i = 0; i < Model.Rovers.Count; i++)
                {
                    <div class="rover-row" style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 15px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <strong>Rover @(i + 1)</strong>
                            @if (i > 0)
                            {
                                <button type="button" class="btn btn-danger btn-small"
                                        onclick="removeRover(this)">
                                    ✕ Remove
                                </button>
                            }
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Start X</label>
                                <input type="number" name="Rovers[@i].StartX" value="@Model.Rovers[i].StartX"
                                       min="0" max="50" class="form-input" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Start Y</label>
                                <input type="number" name="Rovers[@i].StartY" value="@Model.Rovers[i].StartY"
                                       min="0" max="50" class="form-input" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Direction</label>
                                <select name="Rovers[@i].StartDirection" class="form-select" required>
                                    <option value="N" @(Model.Rovers[i].StartDirection == "N" ? "selected" : "")>North (N)</option>
                                    <option value="E" @(Model.Rovers[i].StartDirection == "E" ? "selected" : "")>East (E)</option>
                                    <option value="S" @(Model.Rovers[i].StartDirection == "S" ? "selected" : "")>South (S)</option>
                                    <option value="W" @(Model.Rovers[i].StartDirection == "W" ? "selected" : "")>West (W)</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Commands</label>

                                <input type="text" name="Rovers[@i].Commands" value="@Model.Rovers[i].Commands"
                                       placeholder="e.g., LMLMLMLMM" class="form-input" required
                                       pattern="[LRM]*" title="Only L, R, M allowed">
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <button type="button" class="btn btn-secondary" onclick="addRover()"
                style="margin-bottom: 30px;">
            + Add Rover
        </button>

        <div style="display: flex; gap: 10px;">
            <button type="submit" class="btn btn-primary">
                <span>▶</span>
                <span>Run Simulation</span>
            </button>
            <a href="/" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>

<script>
    // !!! FIX THIS
    let roverCount = @(Model?.Rovers?.Count ?? 0);

    function addRover() {
        const container = document.getElementById('roversContainer');
        const plateauX = document.getElementById('PlateauMaxX').value;
        const plateauY = document.getElementById('PlateauMaxY').value;

        const html = `
            <div class="rover-row" style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 15px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <strong>Rover ${roverCount + 1}</strong>
                    <button type="button" class="btn btn-danger btn-small" onclick="removeRover(this)">
                        ✕ Remove
                    </button>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Start X</label>
                        <input type="number" name="Rovers[${roverCount}].StartX" value="0" min="0" max="50" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Start Y</label>
                        <input type="number" name="Rovers[${roverCount}].StartY" value="0" min="0" max="50" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Direction</label>
                        <select name="Rovers[${roverCount}].StartDirection" class="form-select" required>
                            <option value="N">North (N)</option>
                            <option value="E">East (E)</option>
                            <option value="S">South (S)</option>
                            <option value="W">West (W)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Commands</label>
                        <input type="text" name="Rovers[${roverCount}].Commands" value="" placeholder="e.g., LMLMLMLMM" class="form-input" required pattern="[LRM]*" title="Only L, R, M allowed">
                    </div>
                </div>
            </div>
        `;

        container.insertAdjacentHTML('beforeend', html);
        roverCount++;
    }

    function removeRover(button) {
        button.closest('.rover-row').remove();
    }
</script>
